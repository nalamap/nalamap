# LLM Provider Selection (REQUIRED)
# Choose ONE provider: openai, azure, google, mistral, deepseek, anthropic, moonshot, or xai
LLM_PROVIDER=openai

# Default LLM Provider (OPTIONAL)
# Override which provider appears first in the UI dropdown (selected by default)
# If not set, will use LLM_PROVIDER value. Only affects UI default selection order.
# Example: DEFAULT_LLM_PROVIDER=azure

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Azure OpenAI Configuration
# Model is configured via AZURE_OPENAI_DEPLOYMENT
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2024-08-01-preview
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# For multi-deployment setups, use JSON array:
# AZURE_MODELS_CONFIG=[{"deployment":"gpt-4o","model":"gpt-4o"},{"deployment":"gpt-4o-mini","model":"gpt-4o-mini"}]

# Google AI Configuration
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-1.5-pro-latest

# Mistral AI Configuration
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest

# DeepSeek Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Default: claude-4.5-sonnet

# Moonshot AI (Kimi) Configuration
MOONSHOT_API_KEY=your_moonshot_api_key_here
# Available models: kimi-k2.5, kimi-k2-turbo, moonshot-v1-128k, etc.
# Default: kimi-k2.5

# xAI (Grok) Configuration
XAI_API_KEY=your_xai_api_key_here
# Available models: grok-2-latest, grok-2-vision-latest, grok-beta
# Default: grok-2-latest

# Database Configuration
# Local Docker DB (Uncomment for local development with Docker)
# DATABASE_URL=postgresql://app:app@localhost:5432/app
# Remote DB (Example for Azure deployment)
# DATABASE_AZURE_URL=postgresql://user:password@host:5432/dbname

# Authentication Configuration
# Set AUTH_ENABLED=false to disable authentication entirely (no login/signup required).
# The app will operate with an anonymous user. Useful for local development or demos.
AUTH_ENABLED=true
# Secret key for session signing (REQUIRED in production; backend uses a fixed
# dev-only default when unset — never rely on it outside local development)
# SECRET_KEY=your_secret_key_here

# OIDC Authentication (optional)
# Comma-separated list of OIDC providers to enable
# OIDC_PROVIDERS=google
# OIDC_GOOGLE_ISSUER=https://accounts.google.com
# OIDC_GOOGLE_CLIENT_ID=your_client_id
# OIDC_GOOGLE_CLIENT_SECRET=your_client_secret

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# OGC API storage (optional)
# OGCAPI_BASE_URL is used by backend runtime calls.
# OGCAPI_PUBLIC_BASE_URL is returned to the browser in layer data links.
USE_OGCAPI_STORAGE=false
OGCAPI_BASE_URL=http://ogcapi:8000/v1
OGCAPI_PUBLIC_BASE_URL=http://localhost:8081/v1

# Upload configuration (optional)
# Maximum upload size in bytes. Default: 262144000 (250 MB).
# MAX_FILE_SIZE=262144000

# CORS Configuration (optional)
# Comma-separated list of allowed origins (default: *)
# ALLOWED_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Cookie Security (optional, defaults suitable for production HTTPS)
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax

# ---------------------------------------------------------------------------
# Embedding Configuration (for GeoServer layer search & OSM tag embeddings)
# ---------------------------------------------------------------------------
# Provider for generating embeddings: "hashing" (default, offline), "openai", or "azure"
EMBEDDING_PROVIDER=hashing
# OpenAI embedding model (only used when EMBEDDING_PROVIDER=openai)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Azure embedding deployment (only used when EMBEDDING_PROVIDER=azure)
# AZURE_EMBEDDING_DEPLOYMENT=your_embedding_deployment
# AZURE_EMBEDDING_MODEL=text-embedding-3-small

# Embedding Progress UI Configuration
# Enable/disable smooth interpolation of embedding progress (default: false)
NEXT_PUBLIC_EMBEDDING_INTERPOLATION_ENABLED=false
# Polling interval in milliseconds for checking embedding status (default: 3000)
NEXT_PUBLIC_EMBEDDING_POLLING_INTERVAL_MS=3000
# Default velocity for interpolation in layers per second (default: 3)
NEXT_PUBLIC_EMBEDDING_DEFAULT_VELOCITY=3

# ---------------------------------------------------------------------------
# Agent Performance Configuration
# ---------------------------------------------------------------------------
# Maximum number of recent messages to keep in conversation context (default: 20)
# Set to 0 to disable message pruning. Higher values increase token usage and cost.
MESSAGE_WINDOW_SIZE=20

# Message management strategy for long conversations (default: summarize)
# - 'summarize': Use LLM-based conversation summarization. Older messages are
#   intelligently condensed into a summary, preserving context while reducing tokens.
# - 'prune': Simple window-based truncation. Only keeps the most recent messages;
#   older messages are discarded without summarization.
MESSAGE_MANAGEMENT_MODE=summarize

# ---------------------------------------------------------------------------
# Azure Blob Storage (optional, for cloud file management)
# ---------------------------------------------------------------------------
# USE_AZURE_STORAGE=false
# AZURE_CONN_STRING=your_azure_storage_connection_string
# AZURE_CONTAINER=data
# AZURE_SAS_EXPIRY_HOURS=24

# ---------------------------------------------------------------------------
# Map / WMTS Configuration
# ---------------------------------------------------------------------------
# Filter WMTS layers that lack a WebMercator TileMatrixSet (default: true)
# NALAMAP_FILTER_NON_WEBMERCATOR_WMTS=true

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# LangSmith Tracing (optional, for monitoring AI interactions)
# ---------------------------------------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=your_project_name
