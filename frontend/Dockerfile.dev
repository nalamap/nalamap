# Note: Syntax directive commented out to avoid Docker Hub dependency
# # syntax=docker.io/docker/dockerfile:1

#
# 1. Install dependencies layer
#
FROM node:25-alpine AS deps

WORKDIR /app

# glibc compatibility for some native modules
RUN apk add --no-cache libc6-compat

# copy only manifests & install
COPY package.json yarn.lock* package-lock.json* pnpm-lock.yaml* .npmrc* ./
RUN \
  if [ -f yarn.lock ]; then \
      yarn --frozen-lockfile; \
  elif [ -f package-lock.json ]; then \
      npm ci; \
  elif [ -f pnpm-lock.yaml ]; then \
      corepack enable pnpm && pnpm install --frozen-lockfile; \
  else \
      echo "Lockfile not found." && exit 1; \
  fi

#
# 2. Dev image
#
FROM node:25-alpine AS dev

WORKDIR /app

# glibc compatibility for runtime native modules
RUN apk add --no-cache libc6-compat

# Keep a copy of the installed deps outside /app so bind mounts do not hide them.
COPY --from=deps /app/node_modules /opt/node_modules
COPY package.json yarn.lock* package-lock.json* pnpm-lock.yaml* /opt/deps-manifest/
COPY dev-entrypoint.sh /usr/local/bin/dev-entrypoint
RUN chmod +x /usr/local/bin/dev-entrypoint

# expose Next.js default port
EXPOSE 3000

# dev‐mode env
ENV NODE_ENV=development
ENV HOST=0.0.0.0
ENV PORT=3000

# run the Next.js dev server (hot‑reload)
CMD ["/usr/local/bin/dev-entrypoint"]
